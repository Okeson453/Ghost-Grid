# GHOST GRID Environment Variables Template
# Copy to .env and fill in all values. .env is git-ignored.

# ── Telegram Control Interface ───────────────────────────────────────
TELEGRAM_TOKEN=            # Telegram bot token (get from @BotFather)
TELEGRAM_CHAT_ID=          # Telegram chat ID for alerts (your user ID or group)

# ── MT5 Broker Connection ───────────────────────────────────────────
MT5_LOGIN=                 # MT5 account login number (int)
MT5_PASSWORD=              # MT5 account password
MT5_SERVER=                # MT5 server name (e.g. "MetaQuotes-Demo")

# ── Named Pipe IPC ──────────────────────────────────────────────────
PIPE_PATH=\\.\pipe\ghostgrid   # Windows named pipe path (leave as-is unless MT5 EA uses different)

# ── Runtime Modes ───────────────────────────────────────────────────
PAPER_TRADING=true         # true=paper mode (signals to Telegram only, no orders)
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
VPS_TIMEZONE=UTC           # Always UTC. Local conversion handled by config layer.

# ── Backtesting & Historical Data ───────────────────────────────────
HISTORICAL_DATA_DIR=./data_store/historical   # Path to historical tick CSV files